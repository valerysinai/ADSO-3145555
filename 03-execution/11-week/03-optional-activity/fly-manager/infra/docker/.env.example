# Copiar este archivo a `infra/docker/.env` para uso local no versionado
# o ejecutar `.\infra\tools\inicializar_secretos_locales.ps1`.
# `POSTGRES_USER` es solo para bootstrap interno y uso break-glass via `docker exec`.
# No usar `POSTGRES_USER` / `POSTGRES_PASSWORD` para conectarse desde el host por TCP.
POSTGRES_DB=flydb
POSTGRES_USER=fly_admin
POSTGRES_PASSWORD=FlyAcademicoAdmin2026_Secure
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_PORT=5435
# Usa estos logins para conexiones locales desde el host, DBeaver o `psql -h 127.0.0.1`.
FLY_APP_RW_USER=fly_local_rw
FLY_APP_RW_PASSWORD=FlyAcademicoRW2026_SecurePwd
FLY_APP_RO_USER=fly_local_ro
FLY_APP_RO_PASSWORD=FlyAcademicoRO2026_SecurePwd
FLY_APP_AUDIT_USER=fly_local_audit
FLY_APP_AUDIT_PASSWORD=FlyAcademicoAudit2026_Secure
TZ=America/Bogota
PGTZ=America/Bogota
